#!/bin/bash
# プロジェクト初期化スクリプト
# 使用方法: ./prj-init または source prj-init

echo "🚀 satosystem gen2 - プロジェクト初期化"
echo "=========================================="
echo ""

# プロジェクトルート確認
if [ ! -f "PROGRESS.json" ] || [ ! -f "DEVELOPMENT_RULES.json" ]; then
    echo "❌ エラー: プロジェクトルートから実行してください"
    exit 1
fi

# 背景と役割を表示
echo "🎯 AI役割と背景"
echo "=========================================="
python3 << 'PYEOF'
import json

with open('DEVELOPMENT_RULES.json', 'r') as f:
    rules = json.load(f)

role = rules.get('ai_role_and_background', {}).get('role', {})
background = rules.get('ai_role_and_background', {}).get('background', {})

print(f"\033[1;33m役割:\033[0m {role.get('title', 'N/A')}")
print(f"  📈 年間利回り目標: {role.get('target_annual_return', 'N/A')}")
print(f"  🎯 ミッション: {role.get('mission', 'N/A')}")
print()
print(f"\033[1;31m背景:\033[0m")
print(f"  💰 初期資本: {background.get('user_initial_capital', 'N/A')}")
print(f"  ⚠️  重要性: {background.get('importance', 'N/A')}")
print(f"  🗓️  重要マイルストーン:")
for milestone in background.get('critical_milestones', []):
    print(f"     • {milestone.get('deadline', 'N/A')}: {milestone.get('task', 'N/A')}")
PYEOF
echo ""
echo "=========================================="
echo ""

# 開発ルール表示
echo "📋 開発ルール読み込み中..."
python3 tools/load_development_rules.py

echo ""
echo "=========================================="
echo "📊 現在の進捗状況"
echo "=========================================="

# PROGRESS.jsonとACTION_LIST.jsonから情報を抽出
python3 << 'PYEOF'
import json

# PROGRESS.json読み込み
with open('PROGRESS.json', 'r') as f:
    progress = json.load(f)

# ACTION_LIST.json読み込み
with open('ACTION_LIST.json', 'r') as f:
    action_list = json.load(f)

print(f"✅ ベースライン: {progress['project']['baseline_performance']['cumulative_pnl_usd']} USD")
print(f"📅 最終更新: {progress['project']['last_updated']}")
print(f"🔧 最新コミット: {progress['latest_commit']['hash']} - {progress['latest_commit']['message'][:60]}...")
print()
print(f"📊 タスク統計: TODO={action_list['summary']['todo']}, PROGRESS={action_list['summary']['progress']}, DONE={action_list['summary']['done']}")
print()
print('📌 作業中タスク (PROGRESS):')
for task in action_list['tasks']['progress'][:3]:
    p = task.get('priority', 3)
    priority = p if isinstance(p, str) else '★' * p
    tid = task.get('id') or task.get('task_id', '?')
    print(f"  • {tid}: {task['title']} ({priority})")
print()
print('🎯 次の優先タスク (TODO):')
def _pkey(t):
    p = t.get('priority', 0)
    return p if isinstance(p, int) else len(p)
for task in sorted(action_list['tasks']['todo'], key=_pkey, reverse=True)[:3]:
    p = task.get('priority', 3)
    priority = p if isinstance(p, str) else '★' * p
    tid = task.get('id') or task.get('task_id', '?')
    impact = ''
    if task.get('estimated_impact_usd'):
        impact = f" → 期待効果: +${task['estimated_impact_usd'][0]}-{task['estimated_impact_usd'][1]}/年"
    print(f"  • {tid}: {task['title']} ({priority}){impact}")
print()
print('✅ 最近完了したタスク (DONE):')
for task in action_list['tasks']['done'][-3:]:
    tid = task.get('id') or task.get('task_id', '?')
    cdate = task.get('completed_date') or task.get('completed_at', '?')
    print(f"  • {tid}: {task['title']} ({cdate})")
PYEOF

echo ""
echo "=========================================="
echo "📖 プロジェクト分析読み込み"
echo "=========================================="

# docs/analysis ディレクトリ確認
if [ -d "docs/analysis" ]; then
    echo ""
    echo "📖 docs/analysis/README.md を読み込み中..."
    echo ""
    if [ -f "docs/analysis/README.md" ]; then
        cat docs/analysis/README.md
    else
        echo "⚠️  WARNING: docs/analysis/README.md が見つかりません"
    fi

    echo ""
    echo "=========================================="
    echo "📊 分析ファイル統計"
    echo "=========================================="

    # src/配下のJSON数
    SRC_JSON_COUNT=$(ls docs/analysis/src/*.json 2>/dev/null | wc -l)
    echo "✅ ソースコード分析: ${SRC_JSON_COUNT} ファイル"

    # 主要ファイル確認
    echo ""
    echo "📁 主要分析ファイル:"
    for file in bot config trading_strategy exit_strategy_v2 risk_management price_data_management; do
        if [ -f "docs/analysis/src/${file}.json" ]; then
            echo "  ✅ ${file}.json"
        else
            echo "  ❌ ${file}.json (見つかりません)"
        fi
    done

    echo ""
    echo "=========================================="
    echo "🎯 次のステップ"
    echo "=========================================="
    echo ""
    echo "1. スキーマ確認:"
    echo "   cat docs/analysis/ANALYSIS_SCHEMA_V2.json | jq '.'"
    echo ""
    echo "2. クリティカルモジュール確認:"
    echo "   cat docs/analysis/src/bot.json | jq '.file_overview'"
    echo "   cat docs/analysis/src/trading_strategy.json | jq '.file_overview'"
    echo ""
    echo "3. 全ファイル一覧:"
    echo "   ls -1 docs/analysis/src/"
else
    echo ""
    echo "⚠️  WARNING: docs/analysis ディレクトリが見つかりません"
fi

echo ""
echo "=========================================="
echo "✅ プロジェクト初期化完了"
echo ""
echo "📚 参考ドキュメント:"
echo "  • ACTION_LIST.json - タスク管理（JSON形式）"
echo "  • DEVELOPMENT_RULES.json - 開発ルール（JSON形式）"
echo "  • PROGRESS.json - 進捗状況"
echo ""
echo "🔧 便利コマンド:"
echo "  • ./prj-help - コマンド一覧を表示"
echo "  • ./prj-action-list - 次のアクションプラン（TODO）を表示"
echo "  • python3 tools/update_progress.py --commit"
echo "  • python3 tools/load_development_rules.py"
echo "=========================================="
