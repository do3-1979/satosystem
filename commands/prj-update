#!/bin/bash
# prj-update - PROGRESS.json / ACTION_LIST.json 更新コマンド

set -e

# プロジェクトルート確認
if [ ! -f "PROGRESS.json" ] || [ ! -f "ACTION_LIST.json" ]; then
    echo "❌ エラー: プロジェクトルートから実行してください"
    exit 1
fi

# 引数チェック
if [ $# -eq 0 ]; then
    echo "🔄 プロジェクト更新ツール"
    echo "=========================================="
    echo ""
    echo "使用方法:"
    echo "  ./commands/prj-update commit              # 最新コミット情報を反映"
    echo "  ./commands/prj-update status              # 現在のプロジェクト状況を表示"
    echo "  ./commands/prj-update task-start <ID>     # タスク開始を記録"
    echo "  ./commands/prj-update task-complete <ID>  # タスク完了を記録"
    echo ""
    echo "例:"
    echo "  ./commands/prj-update commit"
    echo "  ./commands/prj-update task-start 40h"
    echo "  ./commands/prj-update task-complete 40d"
    echo ""
    exit 0
fi

COMMAND=$1
shift

case $COMMAND in
    commit)
        echo "📝 最新コミット情報をPROGRESS.jsonに反映..."
        python3 tools/update_progress.py --commit
        ;;

    status)
        echo "📊 プロジェクト現在状況"
        echo "=========================================="
        python3 - << 'PYEOF'
import json

with open('PROGRESS.json', 'r') as f:
    data = json.load(f)
with open('ACTION_LIST.json', 'r') as f:
    al = json.load(f)

print(f"\n🎯 プロジェクト: {data['project']['name']}")
print(f"📈 ベースライン: {data['project']['baseline_performance']['cumulative_pnl_usd']} USD")
print(f"📅 最終更新: {data['project']['last_updated']}")

in_progress = data['current_status']['active_tasks']['in_progress']
print(f"\n🚀 作業中タスク ({len(in_progress)}):")
for task in in_progress:
    tid = task.get('id') or task.get('task_id', '?')
    p = task.get('priority', '?')
    print(f"  [{tid}] {task['title']}")
    print(f"       ステータス: {task.get('status', '?')}  優先度: {p}")

# TODOから次の3件
todos = al['tasks']['todo']
def _pkey(t):
    p = t.get('priority', 0)
    return p if isinstance(p, int) else len(p)
top_todos = sorted(todos, key=_pkey, reverse=True)[:3]
print(f"\n🎯 次の優先タスク ({len(todos)}件中 上位3件):")
for task in top_todos:
    tid = task.get('id') or task.get('task_id', '?')
    print(f"  [{tid}] {task['title']}")

print(f"\n✅ 最近完了 (直近3件):")
for task in al['tasks']['done'][-3:]:
    tid = task.get('id') or task.get('task_id', '?')
    cdate = task.get('completed_date') or task.get('completed_at', '?')
    print(f"  [{tid}] {task['title']} ({cdate})")

print(f"\n💾 最新コミット:")
print(f"  {data['latest_commit']['hash']} - {data['latest_commit']['message']}")
print(f"  日付: {data['latest_commit']['date']}")
PYEOF
        ;;

    task-complete)
        if [ $# -eq 0 ]; then
            echo "❌ エラー: タスクIDを指定してください"
            echo "例: ./commands/prj-update task-complete 40d"
            exit 1
        fi

        TASK_ID=$1

        # ACTION_LIST.json tasks.progress から検索
        TASK_DESC=$(python3 - "$TASK_ID" << 'PYEOF'
import json, sys
task_id = sys.argv[1]

with open('ACTION_LIST.json', 'r') as f:
    al = json.load(f)

# progress から検索
for task in al['tasks']['progress']:
    tid = task.get('id') or task.get('task_id', '')
    if tid == task_id:
        print(f"{task['title']}: 実装完了")
        sys.exit(0)

# todo からも検索（進行中でないタスクを直接完了させる場合）
for task in al['tasks']['todo']:
    tid = task.get('id') or task.get('task_id', '')
    if tid == task_id:
        print(f"{task['title']}: 実装完了")
        sys.exit(0)

print(f"Task {task_id} 実装完了")
PYEOF
)

        echo "✅ タスク完了を記録: $TASK_ID"
        python3 tools/update_progress.py --task-complete "$TASK_ID" --description "$TASK_DESC"
        echo "💡 ACTION_LIST.json の tasks.progress → tasks.done への移動を忘れずに"
        ;;

    task-start)
        if [ $# -eq 0 ]; then
            echo "❌ エラー: タスクIDを指定してください"
            echo "例: ./commands/prj-update task-start 40h"
            exit 1
        fi

        TASK_ID=$1

        # ACTION_LIST.json tasks.todo から検索
        TASK_DESC=$(python3 - "$TASK_ID" << 'PYEOF'
import json, sys
task_id = sys.argv[1]

with open('ACTION_LIST.json', 'r') as f:
    al = json.load(f)

for task in al['tasks']['todo']:
    tid = task.get('id') or task.get('task_id', '')
    if tid == task_id:
        print(f"{task['title']}: 実装開始")
        sys.exit(0)

print(f"Task {task_id} 実装開始")
PYEOF
)

        echo "🚀 タスク開始を記録: $TASK_ID"
        python3 tools/update_progress.py --task-start "$TASK_ID" --description "$TASK_DESC"
        echo "💡 ACTION_LIST.json の tasks.todo → tasks.progress への移動を忘れずに"
        ;;

    *)
        echo "❌ エラー: 不明なコマンド '$COMMAND'"
        echo ""
        echo "使用可能なコマンド: commit / status / task-start / task-complete"
        exit 1
        ;;
esac

echo ""
echo "=========================================="
