#!/bin/bash
# prj-update-analysis - ソースコード分析ファイル自動更新
# ソースコードと分析ファイルの整合性を確認し、必要に応じて更新

set -e

echo "🔍 ソースコード分析ファイル自動更新"
echo "=========================================="
echo ""

# プロジェクトルート確認
if [ ! -d "docs/analysis/src" ] || [ ! -d "src" ]; then
    echo "❌ エラー: プロジェクトルートから実行してください"
    exit 1
fi

# スキーマ読み込み
echo "📖 ANALYSIS_SCHEMA_V2.json 読み込み..."
if [ ! -f "docs/analysis/ANALYSIS_SCHEMA_V2.json" ]; then
    echo "❌ エラー: ANALYSIS_SCHEMA_V2.json が見つかりません"
    exit 1
fi

echo "✅ 分析スキーマ確認完了"
echo ""

# ソースファイルと分析ファイルの整合性チェック
echo "=========================================="
echo "📂 ソースファイルと分析ファイルの対応確認"
echo "=========================================="

python3 << 'PYEOF'
import os
import json
import glob
from datetime import datetime

# ソースファイル一覧取得
src_files = glob.glob('src/*.py')
src_files = [f for f in src_files if not f.endswith('__init__.py')]
src_files = sorted(src_files)

# 分析ファイル一覧取得
analysis_files = glob.glob('docs/analysis/src/*.json')
analysis_map = {}

for analysis_file in analysis_files:
    with open(analysis_file, 'r') as f:
        try:
            data = json.load(f)
            # ANALYSIS_SCHEMA_V2.json に準拠したフィールド名を使用
            source = data.get('metadata', {}).get('source_file', '')
            analyzed_at = data.get('metadata', {}).get('analyzed_at', 'N/A')
            
            # analyzed_at から日付部分だけ抽出 (YYYY-MM-DD)
            if analyzed_at != 'N/A' and 'T' in analyzed_at:
                analyzed_at = analyzed_at.split('T')[0]
            
            if source:
                analysis_map[source] = {
                    'analysis_file': analysis_file,
                    'last_updated': analyzed_at
                }
        except Exception as e:
            print(f"⚠️  {analysis_file}: JSON読み込みエラー - {e}")

print(f"✅ ソースファイル: {len(src_files)}件")
print(f"✅ 分析ファイル: {len(analysis_files)}件")
print()

# 対応チェック
needs_update = []
missing_analysis = []

for src_file in src_files:
    src_rel = src_file
    
    # 対応する分析ファイルの確認
    if src_rel in analysis_map:
        analysis_info = analysis_map[src_rel]
        
        # ソースファイルの更新日時
        src_mtime = os.path.getmtime(src_file)
        src_date = datetime.fromtimestamp(src_mtime).strftime('%Y-%m-%d')
        
        # 分析ファイルの更新日時
        analysis_date = analysis_info['last_updated']
        
        if analysis_date == 'N/A' or src_date > analysis_date:
            needs_update.append({
                'source': src_file,
                'analysis': analysis_info['analysis_file'],
                'src_date': src_date,
                'analysis_date': analysis_date
            })
            print(f"🔄 要更新: {os.path.basename(src_file)}")
            print(f"   ソース: {src_date} | 分析: {analysis_date}")
        else:
            print(f"✅ 最新: {os.path.basename(src_file)}")
    else:
        missing_analysis.append(src_file)
        print(f"❌ 未分析: {os.path.basename(src_file)}")

print()
print("==========================================")
print(f"📊 サマリー")
print("==========================================")
print(f"  最新状態: {len(src_files) - len(needs_update) - len(missing_analysis)}件")
print(f"  更新必要: {len(needs_update)}件")
print(f"  未分析: {len(missing_analysis)}件")

if needs_update or missing_analysis:
    print()
    print("⚠️  以下のファイルを更新する必要があります:")
    for item in needs_update:
        print(f"  • {os.path.basename(item['source'])}")
    for src in missing_analysis:
        print(f"  • {os.path.basename(src)} (新規)")
    print()
    print("📝 更新手順:")
    print("  1. 各ソースファイルを読み込み、構造を分析")
    print("  2. ANALYSIS_SCHEMA_V2.json に準拠した分析結果を生成")
    print("  3. docs/analysis/src/<module>.json に保存")
    print()
    print("🔧 手動更新する場合:")
    print("  AIアシスタントに「<module>.pyの分析ファイルを更新して」と依頼")
else:
    print()
    print("✅ すべての分析ファイルが最新です")

PYEOF

echo ""
echo "=========================================="
echo "✅ 分析ファイル確認完了"
echo "=========================================="
