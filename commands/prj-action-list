#!/bin/bash
# prj-action-list - 次のアクションプラン（TODO）を表示

# 色定義
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m' # No Color

echo "=========================================="
echo "🎯 次のアクションプラン（TODO）"
echo "=========================================="
echo ""

# ファイル存在確認
if [ ! -f "ACTION_LIST.json" ]; then
    echo -e "${RED}❌ エラー: ACTION_LIST.json が見つかりません${NC}"
    exit 1
fi

if [ ! -f "PROGRESS.json" ]; then
    echo -e "${RED}❌ エラー: PROGRESS.json が見つかりません${NC}"
    exit 1
fi

# PROGRESS.jsonから基本情報を取得
BASELINE=$(python3 -c "import json; f=open('PROGRESS.json'); data=json.load(f); print(data.get('project', {}).get('baseline_performance', {}).get('cumulative_pnl_usd', 'N/A'))" 2>/dev/null)
LAST_UPDATE=$(python3 -c "import json; f=open('PROGRESS.json'); data=json.load(f); print(data.get('project', {}).get('last_updated', 'N/A'))" 2>/dev/null)
TARGET=$(python3 -c "import json; f=open('PROGRESS.json'); data=json.load(f); print(data.get('performance_goals_2026', {}).get('target', 'N/A'))" 2>/dev/null)

echo -e "${GREEN}📊 現在の状況${NC}"
echo "=========================================="
echo -e "${BLUE}ベースライン性能:${NC} $BASELINE USD (2024-2025, 8四半期)"
echo -e "${BLUE}2026年目標:${NC} $TARGET"
echo -e "${BLUE}最終更新:${NC} $LAST_UPDATE"
echo ""

# ACTION_LIST.jsonからタスク情報を表示
python3 << 'EOF'
import json

# ファイル読み込み
with open('ACTION_LIST.json', 'r') as f:
    action_list = json.load(f)

with open('PROGRESS.json', 'r') as f:
    progress = json.load(f)

print("==========================================")
print("\033[0;35m⭐ 最優先タスク (★★★★★)\033[0m")
print("==========================================")

# 優先度5のタスクを表示
high_priority = [t for t in action_list['tasks']['todo'] if t['priority'] == 5]
for task in high_priority:
    impact = ''
    if task.get('estimated_impact_usd'):
        impact = f" → 期待効果: +${task['estimated_impact_usd'][0]}-{task['estimated_impact_usd'][1]}/年"
    print(f"\n[{task['id']}] {task['title']}")
    print(f"    {task['description']}{impact}")
    print(f"    カテゴリ: {task['category']}")

print("\n==========================================")
print("\033[1;33m🎯 高優先度タスク (★★★★☆)\033[0m")
print("==========================================")

# 優先度4のタスクを表示
mid_priority = [t for t in action_list['tasks']['todo'] if t['priority'] == 4]
for task in mid_priority:
    impact = ''
    if task.get('estimated_impact_usd'):
        impact = f" → 期待効果: +${task['estimated_impact_usd'][0]}-{task['estimated_impact_usd'][1]}/年"
    elif task.get('estimated_hours'):
        impact = f" → 予想工数: {task['estimated_hours'][0]}-{task['estimated_hours'][1]}時間"
    print(f"\n[{task['id']}] {task['title']}")
    print(f"    {task['description']}{impact}")
    print(f"    カテゴリ: {task['category']}")

print("\n==========================================")
print("\033[0;36m📋 作業中タスク (PROGRESS)\033[0m")
print("==========================================")

for task in action_list['tasks']['progress']:
    priority_stars = '★' * task['priority']
    print(f"\n[{task['id']}] {task['title']} ({priority_stars})")
    print(f"    {task['description']}")
    print(f"    状態: {task['status']}")

print("\n==========================================")
print("\033[0;32m✅ 統計情報\033[0m")
print("==========================================")
summary = action_list['summary']
print(f"TODO: {summary['todo']}件 | PROGRESS: {summary['progress']}件 | DONE: {summary['done']}件")
print(f"累積利益: {summary['cumulative_impact_usd']} USD")

print("\n==========================================")
print("\033[0;32m📝 推奨アクション\033[0m")
print("==========================================")
print("1. タスク開始: ./commands/prj-update task-start <task_id>")
print("2. タスク完了: ./commands/prj-update task-complete <task_id>")
print("3. 詳細確認: cat ACTION_LIST.json | jq '.tasks.todo'")
print("==========================================")
EOF


# 優先度★★★★★のタスクを表示
high_priority = [task for task in next_priority if task.get('priority') == '★★★★★']

for i, task in enumerate(high_priority, 1):
    task_id = task.get('task_id', 'N/A')
    title = task.get('title', 'N/A')
    description = task.get('description', 'N/A')
    benefit = task.get('expected_benefit', 'N/A')
    
    print(f"\n{i}. [{task_id}] {title}")
    print(f"   📝 内容: {description}")
    print(f"   💰 期待効果: {benefit}")
    
    # performance_goalsから詳細情報を取得
    if task_id == '39b':
        contrib = performance_goals.get('39b_two_tier_entry', 'N/A')
        print(f"   📈 年間貢献: {contrib}")
    elif task_id == '39c':
        contrib = performance_goals.get('39c_multi_timeframe', 'N/A')
        print(f"   📈 年間貢献: {contrib}")

EOF

# 次点タスク（★★★★☆）を表示
echo ""
echo "=========================================="
echo -e "${CYAN}📋 次点タスク (★★★★☆)${NC}"
echo "=========================================="

python3 << 'EOF'
import json

with open('PROGRESS.json', 'r') as f:
    data = json.load(f)

next_priority = data.get('current_status', {}).get('active_tasks', {}).get('next_priority', [])
performance_goals = data.get('performance_goals_2026', {}).get('strategy_contributions', {})

# 優先度★★★★☆のタスクを表示
medium_priority = [task for task in next_priority if task.get('priority') == '★★★★☆']

for task in medium_priority:
    task_id = task.get('task_id', 'N/A')
    title = task.get('title', 'N/A')
    description = task.get('description', 'N/A')
    benefit = task.get('expected_benefit', 'N/A')
    
    print(f"\n• [{task_id}] {title}")
    print(f"  📝 {description}")
    print(f"  💰 {benefit}")
    
    # performance_goalsから詳細情報を取得
    if task_id == '39d':
        contrib = performance_goals.get('39d_time_based_exit', 'N/A')
        print(f"  📈 年間貢献: {contrib}")
    elif task_id == '39e':
        contrib = performance_goals.get('39e_dynamic_stop_loss', 'N/A')
        print(f"  📈 年間貢献: {contrib}")
    elif task_id == '39f':
        contrib = performance_goals.get('39f_weekend_avoidance', 'N/A')
        print(f"  📈 年間貢献: {contrib}")

EOF

# 作業中タスクを表示
echo ""
echo "=========================================="
echo -e "${YELLOW}🔧 作業中タスク${NC}"
echo "=========================================="

python3 << 'EOF'
import json

with open('PROGRESS.json', 'r') as f:
    data = json.load(f)

in_progress = data.get('current_status', {}).get('active_tasks', {}).get('in_progress', [])

if in_progress:
    for task in in_progress:
        task_id = task.get('task_id', 'N/A')
        title = task.get('title', 'N/A')
        status = task.get('status', 'N/A')
        priority = task.get('priority', 'N/A')
        
        print(f"\n• [{task_id}] {title}")
        print(f"  状態: {status}")
        print(f"  優先度: {priority}")
else:
    print("\n作業中のタスクはありません")

EOF

# 推奨アクション
echo ""
echo "=========================================="
echo -e "${GREEN}💡 推奨アクション${NC}"
echo "=========================================="
echo ""
echo "🎯 次に実行すべきこと:"
echo ""
echo "1. 最優先タスク (39b または 39c) を選択"
echo "   → 39b: 実装が比較的容易、確実な利益改善"
echo "   → 39c: 効果が最大、ただし実装複雑度が高い"
echo ""
echo "2. タスク開始を記録:"
echo -e "   ${CYAN}python3 tools/update_progress.py --task-start 39b --description \"実装開始\"${NC}"
echo ""
echo "3. 実装・テスト実施（DEVELOPMENT_RULES.json参照）"
echo ""
echo "4. レグレッションテスト実行:"
echo -e "   ${CYAN}./commands/prj-run-regression${NC}"
echo ""
echo "5. タスク完了を記録:"
echo -e "   ${CYAN}python3 tools/update_progress.py --task-complete 39b --description \"実装完了\"${NC}"
echo ""
echo "=========================================="
