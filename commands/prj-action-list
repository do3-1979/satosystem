#!/bin/bash
# prj-action-list - 次のアクションプラン（TODO/PROGRESS）を表示

# 色定義
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

echo "=========================================="
echo "🎯 アクションプラン"
echo "=========================================="
echo ""

# ファイル存在確認
if [ ! -f "ACTION_LIST.json" ] || [ ! -f "PROGRESS.json" ]; then
    echo -e "${RED}❌ エラー: プロジェクトルートから実行してください${NC}"
    exit 1
fi

# PROGRESS.jsonから基本情報を取得
BASELINE=$(python3 -c "
import json
with open('ACTION_LIST.json') as f:
    al = json.load(f)
s = al.get('summary', {})
print(s.get('baseline_performance', 'N/A'))" 2>/dev/null)

LAST_UPDATE=$(python3 -c "import json; f=open('PROGRESS.json'); data=json.load(f); print(data.get('project', {}).get('last_updated', 'N/A'))" 2>/dev/null)
TARGET=$(python3 -c "import json; f=open('PROGRESS.json'); data=json.load(f); print(data.get('performance_goals_2026', {}).get('target', 'N/A'))" 2>/dev/null)

echo -e "${GREEN}📊 現在の状況${NC}"
echo "=========================================="
echo -e "${BLUE}ベースライン:${NC} $BASELINE"
echo -e "${BLUE}2026年目標:${NC} $TARGET"
echo -e "${BLUE}最終更新:${NC} $LAST_UPDATE"
echo ""

python3 - << 'PYEOF'
import json

with open('ACTION_LIST.json', 'r') as f:
    al = json.load(f)

todos = al['tasks']['todo']
progress_tasks = al['tasks']['progress']

def tid(t):
    return t.get('id') or t.get('task_id', '?')

def pkey(t):
    p = t.get('priority', 0)
    return p if isinstance(p, int) else len(p)

# --------- 作業中 ---------
print("\033[0;36m==========================================")
print("📋 作業中タスク (PROGRESS)")
print("==========================================\033[0m")
if not progress_tasks:
    print("  (なし)")
for task in progress_tasks:
    p = task.get('priority', 3)
    stars = p if isinstance(p, str) else '★' * p
    print(f"\n  [{tid(task)}] {task['title']} ({stars})")
    print(f"      状態: {task.get('status', '作業中')}")
    if task.get('due_date'):
        print(f"      期限: {task['due_date']}")

# --------- 最優先 (priority=5) ---------
p5 = [t for t in todos if t.get('priority') == 5]
if p5:
    print("\n\033[0;35m==========================================")
    print("⭐ 最優先タスク (★★★★★)")
    print("==========================================\033[0m")
    for t in p5:
        print(f"\n  [{tid(t)}] {t['title']}")
        print(f"      {t.get('description','')[:80]}")
        print(f"      カテゴリ: {t.get('category','?')}")

# --------- 高優先 (priority=4) ---------
p4 = [t for t in todos if t.get('priority') == 4]
if p4:
    print("\n\033[1;33m==========================================")
    print("🎯 高優先度タスク (★★★★☆)")
    print("==========================================\033[0m")
    for t in p4:
        extra = ''
        if t.get('estimated_impact_usd'):
            extra = f" → 期待効果: +${t['estimated_impact_usd'][0]}-{t['estimated_impact_usd'][1]}/年"
        elif t.get('estimated_hours'):
            extra = f" → 予想工数: {t['estimated_hours'][0]}-{t['estimated_hours'][1]}時間"
        print(f"\n  [{tid(t)}] {t['title']}{extra}")
        print(f"      {t.get('description','')[:80]}")
        print(f"      カテゴリ: {t.get('category','?')}")

# --------- 通常 (priority=3) ---------
p3 = [t for t in todos if t.get('priority') == 3]
if p3:
    print("\n\033[0;34m==========================================")
    print("📌 通常優先度タスク (★★★☆☆)")
    print("==========================================\033[0m")
    for t in p3:
        print(f"  [{tid(t)}] {t['title']}")

# --------- バックログ (priority<=2) ---------
backlog = [t for t in todos if pkey(t) <= 2]
if backlog:
    print("\n\033[0;37m==========================================")
    print("🗂  バックログ (★★☆☆☆ 以下)")
    print("==========================================\033[0m")
    for t in sorted(backlog, key=pkey, reverse=True):
        print(f"  [{tid(t)}] {t['title']}")

# --------- 統計 ---------
s = al['summary']
print("\n\033[0;32m==========================================")
print("✅ 統計情報")
print("==========================================\033[0m")
print(f"  TODO: {s['todo']}件 | PROGRESS: {s['progress']}件 | DONE: {s['done']}件")
print(f"  累積損益: {s['cumulative_impact_usd']} USD")

print("\n==========================================")
print("📝 操作コマンド")
print("==========================================")
print("  タスク開始: ./commands/prj-update task-start <ID>")
print("  タスク完了: ./commands/prj-update task-complete <ID>")
print("  詳細確認:   cat ACTION_LIST.json | python3 -c \"import json,sys; [print(t) for t in json.load(sys.stdin)['tasks']['todo']]\"")
print("==========================================")
PYEOF
