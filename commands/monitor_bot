#!/bin/bash
# ============================================================
#  satosystem BOT ライブモニター
#  latest_status.json をベースに表示
#  使い方:
#    ./commands/monitor_bot                      # ローカル
#    ./commands/monitor_bot --host raspberry_pi  # SSH経由
#  更新間隔: 30秒
# ============================================================

cd "$(git rev-parse --show-toplevel 2>/dev/null || echo "$HOME/work/satosystem")" || exit 1

LOCAL_LOGS_BTC="src/logs"
LOCAL_LOGS_XAUT="src/logs/xaut"
INTERVAL=30
SSH_HOST=""
ASSET="BTC"  # デフォルト: BTC

# 引数解析
PREV=""
for i in "$@"; do
  case "$i" in --host=*) SSH_HOST="${i#*=}" ;; esac
  if [ "$PREV" = "--host" ]; then SSH_HOST="$i"; fi
  case "$i" in --asset=*) ASSET="${i#*=}" ;; esac
  if [ "$PREV" = "--asset" ]; then ASSET="$i"; fi
  case "$i" in --xaut) ASSET="XAUT" ;; esac
  PREV="$i"
done

# ログディレクトリ設定
if [ "$ASSET" = "XAUT" ]; then
    LOCAL_LOGS_DIR="$LOCAL_LOGS_XAUT"
    CONFIG_NAME="config_xaut.ini"
else
    LOCAL_LOGS_DIR="$LOCAL_LOGS_BTC"
    CONFIG_NAME="config.ini"
fi
STATUS_FILE="$LOCAL_LOGS_DIR/latest_status.json"

# カラーコード
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
WHITE='\033[1;37m'
GRAY='\033[0;37m'
BOLD='\033[1m'
RESET='\033[0m'

# latest_status.json を取得（SSH or ローカル）
fetch_status_json() {
    if [ -n "$SSH_HOST" ]; then
        ssh "$SSH_HOST" "cat ~/work/satosystem/$LOCAL_LOGS_DIR/latest_status.json" 2>/dev/null
    else
        cat "$STATUS_FILE" 2>/dev/null
    fi
}

# プロセス状態取得（SSH or ローカル）
get_proc_info() {
    if [ -n "$SSH_HOST" ]; then
        ssh "$SSH_HOST" "
            PID=\$(pgrep -f \"python3 -u bot.py.*$CONFIG_NAME\" | head -1)
            if [ -n \"\$PID\" ]; then
                CPU=\$(ps -p \$PID -o %cpu --no-headers 2>/dev/null | tr -d ' ')
                MEM=\$(ps -p \$PID -o %mem --no-headers 2>/dev/null | tr -d ' ')
                STARTED=\$(ps -p \$PID -o lstart --no-headers 2>/dev/null | xargs)
                echo \"pid=\$PID cpu=\$CPU mem=\$MEM started=\$STARTED\"
            else
                echo 'pid='
            fi" 2>/dev/null
    else
        local pid
        pid=$(pgrep -f "python3 -u bot.py.*$CONFIG_NAME" | head -1)
        if [ -n "$pid" ]; then
            local cpu mem started
            cpu=$(ps -p "$pid" -o %cpu --no-headers 2>/dev/null | tr -d ' ')
            mem=$(ps -p "$pid" -o %mem --no-headers 2>/dev/null | tr -d ' ')
            started=$(ps -p "$pid" -o lstart --no-headers 2>/dev/null | xargs)
            echo "pid=$pid cpu=$cpu mem=$mem started=$started"
        else
            echo "pid="
        fi
    fi
}

# ラベルを固定幅で出力（等幅フォント用: 全角2字=半角4字 として揃える）
# 使い方: lbl "ラベル" 半角換算幅
lbl() {
    local text="$1" width="${2:-14}"
    # 全角文字数をカウント（日本語等）して実バイト幅を補正
    local visual
    visual=$(echo -n "$text" | python3 -c "
import sys, unicodedata
s = sys.stdin.read()
w = sum(2 if unicodedata.east_asian_width(c) in ('W','F') else 1 for c in s)
print(w)" 2>/dev/null || echo ${#text})
    local pad=$(( width - visual ))
    [ $pad -lt 0 ] && pad=0
    printf "%s%*s" "$text" $pad ""
}

show_dashboard() {
    clear
    local now
    now=$(date '+%Y-%m-%d %H:%M:%S')
    local target_label=""
    [ -n "$SSH_HOST" ] && target_label=" [${SSH_HOST}]"

    # ヘッダー（固定68文字幅）
    local asset_display="$ASSET"
    [ "$ASSET" = "BTC" ] && asset_display="Bitcoin (BTC)"
    [ "$ASSET" = "XAUT" ] && asset_display="Gold (XAUT)"
    
    echo -e "${BOLD}${CYAN}╔════════════════════════════════════════════════════════════════════╗${RESET}"
    printf "${BOLD}${CYAN}║${RESET}  ${WHITE}satosystem BOT モニター — ${asset_display}${target_label}${RESET}  ${GRAY}${now}${RESET}
"
    echo -e "${BOLD}${CYAN}╚════════════════════════════════════════════════════════════════════╝${RESET}"
    echo ""

    # ── プロセス状態 ──
    local proc_out
    proc_out=$(get_proc_info)
    local pid cpu_val mem_val started_val
    pid=$(echo "$proc_out"     | grep -oP 'pid=\K\S*')
    cpu_val=$(echo "$proc_out" | grep -oP 'cpu=\K\S*')
    mem_val=$(echo "$proc_out" | grep -oP 'mem=\K\S*')
    started_val=$(echo "$proc_out" | grep -oP 'started=\K.*')

    if [ -n "$pid" ]; then
        printf "  ${BOLD}%-14s${RESET}  ${GREEN}● 稼働中${RESET}  PID:${WHITE}%-8s${RESET}  CPU:${YELLOW}%s%%${RESET}  MEM:${YELLOW}%s%%${RESET}\n" \
            "プロセス" "$pid" "$cpu_val" "$mem_val"
        [ -n "$started_val" ] && printf "  ${GRAY}%-14s${RESET}  %s\n" "起動時刻" "$started_val"
    else
        printf "  ${BOLD}%-14s${RESET}  ${RED}● 停止中${RESET}\n" "プロセス"
    fi
    echo ""

    # ── latest_status.json 読み込み ──
    local json_data
    json_data=$(fetch_status_json)

    if [ -z "$json_data" ]; then
        printf "  ${RED}latest_status.json が見つかりません${RESET}\n"
        echo ""
        printf "  ${GRAY}更新間隔: %s秒  終了: Ctrl+C${RESET}\n" "$INTERVAL"
        return
    fi

    # python3 で一気にパース → eval 用変数を出力
    eval "$(echo "$json_data" | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    l = d.get('latest', {})
    candles = d.get('candles', [])
    errors  = d.get('recent_errors', [])

    def q(v): return str(v).replace('\"','').replace(\"'\",\"\")

    print(f'J_UPDATED=\"{q(d.get(\"updated_at\",\"\"))}\"')
    print(f'J_TS=\"{q(l.get(\"ts\",\"\"))}\"')
    print(f'J_HIGH={int(l.get(\"high\",0))}')
    print(f'J_LOW={int(l.get(\"low\",0))}')
    print(f'J_CLOSE={int(l.get(\"close\",0))}')
    print(f'J_BUY_PRICE={int(l.get(\"buy_price\",0))}')
    print(f'J_STOP={int(l.get(\"stop\",0))}')
    print(f'J_VOLA={float(l.get(\"volatility\",0)):.2f}')
    print(f'J_VOLUME={float(l.get(\"volume\",0)):.2f}')
    print(f'J_DECISION=\"{q(l.get(\"decision\",\"\"))}\"')
    print(f'J_SIDE=\"{q(l.get(\"side\",\"\"))}\"')
    print(f'J_QTY={float(l.get(\"asset\",0)):.4f}')
    print(f'J_POS=\"{q(l.get(\"position_side\",\"NONE\"))}\"')
    print(f'J_PNL={int(l.get(\"pnl\",0))}')
    print(f'J_TOTAL_PNL={int(l.get(\"total_pnl\",0))}')
    print(f'J_PVO={float(l.get(\"pvo_val\",0)):.2f}')
    print(f'J_ADX={float(l.get(\"adx\",0)):.1f}')
    print(f'J_PSAR={int(l.get(\"psar\",0))}')
    print(f'J_DC_H={int(l.get(\"dc_h\",0))}')
    print(f'J_DC_L={int(l.get(\"dc_l\",0))}')
    print(f'J_ERR_COUNT={int(d.get(\"error_count\",0))}')
    print(f'J_CANDLE_COUNT={len(candles)}')

    # 直近5本のカーソル履歴
    for i, c in enumerate(candles[-5:]):
        print(f'J_CH{i}_TS=\"{q(c.get(\"ts\",\"\"))}\"')
        print(f'J_CH{i}_DEC=\"{q(c.get(\"decision\",\"\"))}\"')
        print(f'J_CH{i}_CLOSE={int(c.get(\"close\",0))}')
        print(f'J_CH{i}_POS=\"{q(c.get(\"position_side\",\"\"))}\"')
        print(f'J_CH{i}_PNL={int(c.get(\"total_pnl\",0))}')

    # 直近3エラー
    for i, e in enumerate(errors[-3:]):
        msg = q(e.get('msg',''))[:70]
        print(f'J_ERR{i}_TS=\"{q(e.get(\"ts\",\"\"))}\"')
        print(f'J_ERR{i}_MSG=\"{msg}\"')

    print('J_OK=1')
except Exception as ex:
    print(f'J_OK=0')
    print(f'J_PARSE_ERROR=\"{ex}\"')
" 2>/dev/null)"

    if [ "${J_OK:-0}" != "1" ]; then
        printf "  ${RED}JSON解析エラー: %s${RESET}\n" "$J_PARSE_ERROR"
        echo ""
        printf "  ${GRAY}更新間隔: %s秒  終了: Ctrl+C${RESET}\n" "$INTERVAL"
        return
    fi

    # ボラティリティ色分け（閾値2500）
    local vola_int=${J_VOLA%.*}
    local vola_color="$GREEN"
    [ "${vola_int:-0}" -ge 2500 ] 2>/dev/null && vola_color="$RED"
    [ "${vola_int:-0}" -ge 2000 ] 2>/dev/null && [ "${vola_int:-0}" -lt 2500 ] && vola_color="$YELLOW"

    # ADX色分け（閾値31）
    local adx_int=${J_ADX%.*}
    local adx_color="$GRAY"
    [ "${adx_int:-0}" -ge 31 ] 2>/dev/null && adx_color="$GREEN"

    # PVO色分け（閾値10）
    local pvo_color="$GRAY"
    python3 -c "exit(0 if float('${J_PVO:-0}') >= 10 else 1)" 2>/dev/null && pvo_color="$GREEN"

    # シグナル色分け
    local sig_color="$GRAY"
    echo "$J_DECISION" | grep -qiE "entry|buy|sell" && sig_color="$GREEN"

    # ポジション色分け
    local pos_color="$GRAY"
    [ "$J_POS" = "BUY"  ] && pos_color="$GREEN"
    [ "$J_POS" = "SELL" ] && pos_color="$RED"

    # 損益色分け
    local pnl_color="$GRAY"
    [ "${J_PNL:-0}"       -gt 0 ] 2>/dev/null && pnl_color="$GREEN"
    [ "${J_PNL:-0}"       -lt 0 ] 2>/dev/null && pnl_color="$RED"
    local tpnl_color="$GRAY"
    [ "${J_TOTAL_PNL:-0}" -gt 0 ] 2>/dev/null && tpnl_color="$GREEN"
    [ "${J_TOTAL_PNL:-0}" -lt 0 ] 2>/dev/null && tpnl_color="$RED"

    # ── 最新データパネル（等幅: 右辺枠なし・printf固定幅）──
    printf "  ${BOLD}${WHITE}\u250c\u2500\u2500 ${GRAY}\u6700\u65b0\u30c7\u30fc\u30bf  (\u66f4\u65b0: %s) ${WHITE}\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500${RESET}\n" "$J_UPDATED"
    printf "  ${GRAY}\u2502${RESET}  %-14s  ${WHITE}%s${RESET}\n"                        "$(lbl '時刻' 14)" "$J_TS"
    printf "  ${GRAY}\u2502${RESET}\n"
    printf "  ${GRAY}\u2502${RESET}  %-14s  ${WHITE}%-10s${RESET}  ${GRAY}高値:${RESET}${YELLOW}%-10s${RESET}  ${GRAY}安値:${RESET}${BLUE}%-10s${RESET}  ${GRAY}PSAR:${RESET}${GRAY}%s${RESET}\n" \
        "$(lbl 'BTC終値' 14)" "$J_CLOSE" "$J_HIGH" "$J_LOW" "$J_PSAR"
    printf "  ${GRAY}\u2502${RESET}  %-14s  ${GRAY}上限:${RESET}${YELLOW}%-10s${RESET}  ${GRAY}下限:${RESET}${BLUE}%s${RESET}\n" \
        "$(lbl 'DC帯' 14)" "$J_DC_H" "$J_DC_L"
    printf "  ${GRAY}\u2502${RESET}  ${GRAY}\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500${RESET}\n"
    printf "  ${GRAY}\u2502${RESET}  %-14s  ${sig_color}${BOLD}%-10s${RESET}  ${GRAY}サイド:${RESET}%s\n" \
        "$(lbl '判断' 14)" "$J_DECISION" "$J_SIDE"
    printf "  ${GRAY}\u2502${RESET}  %-14s  ${pos_color}%-8s${RESET}  ${GRAY}保有:${RESET}${WHITE}%s BTC${RESET}  ${GRAY}購入価:${RESET}${WHITE}%-10s${RESET}  ${GRAY}STOP:${RESET}${RED}%s${RESET}\n" \
        "$(lbl 'ポジション' 14)" "$J_POS" "$J_QTY" "$J_BUY_PRICE" "$J_STOP"
    printf "  ${GRAY}\u2502${RESET}  %-14s  ${pnl_color}%-10s${RESET}  ${GRAY}累計損益:${RESET}  ${tpnl_color}%s USD${RESET}\n" \
        "$(lbl 'みなし損益' 14)" "${J_PNL} USD" "$J_TOTAL_PNL"
    printf "  ${GRAY}\u2502${RESET}  ${GRAY}\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500${RESET}\n"
    printf "  ${GRAY}\u2502${RESET}  %-14s  ${vola_color}%-6s${RESET}${GRAY}/2500${RESET}  ${GRAY}ADX:${RESET}${adx_color}%-6s${RESET}${GRAY}/31${RESET}  ${GRAY}PVO:${RESET}${pvo_color}%-8s${RESET}${GRAY}/10${RESET}  ${GRAY}出来高:${RESET}${WHITE}%s${RESET}\n" \
        "$(lbl 'ボラ' 14)" "$J_VOLA" "$J_ADX" "$J_PVO" "$J_VOLUME"
    printf "  ${BOLD}${WHITE}\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500${RESET}\n"
    echo ""

    # ── エラー表示 ──
    if [ "${J_ERR_COUNT:-0}" -gt 0 ] 2>/dev/null; then
        printf "  ${RED}${BOLD}⚠  エラー: %s件${RESET}\n" "$J_ERR_COUNT"
        for i in 0 1 2; do
            local ts_var="J_ERR${i}_TS"
            local msg_var="J_ERR${i}_MSG"
            local ts="${!ts_var}" msg="${!msg_var}"
            [ -n "$ts" ] && printf "  ${RED}  %-17s  %s${RESET}\n" "$ts" "$msg"
        done
    else
        printf "  ${GREEN}✓  エラー: なし${RESET}\n"
    fi
    echo ""

    # ── 直近ローソク足履歴 ──
    if [ "${J_CANDLE_COUNT:-0}" -gt 0 ] 2>/dev/null; then
        printf "  ${BOLD}${WHITE}直近ローソク足履歴 (%s本):${RESET}\n" "$J_CANDLE_COUNT"
        printf "  ${GRAY}  %-17s  %-10s  %-10s  %-6s  %s${RESET}\n" \
            "時刻" "判断" "終値" "ポジ" "累計損益"
        printf "  ${GRAY}  %-17s  %-10s  %-10s  %-6s  %s${RESET}\n" \
            "─────────────────" "──────────" "──────────" "──────" "────────"
        for i in 4 3 2 1 0; do
            local ts_var="J_CH${i}_TS"
            local dec_var="J_CH${i}_DEC"
            local close_var="J_CH${i}_CLOSE"
            local pos_var="J_CH${i}_POS"
            local pnl_var="J_CH${i}_PNL"
            local cts="${!ts_var}" cdec="${!dec_var}" cclose="${!close_var}" cpos="${!pos_var}" cpnl="${!pnl_var}"
            [ -z "$cts" ] && continue
            local hcolor="$GRAY"
            echo "$cdec" | grep -qiE "entry|buy|sell" && hcolor="$GREEN"
            local cpnl_color="$GRAY"
            [ "${cpnl:-0}" -gt 0 ] 2>/dev/null && cpnl_color="$GREEN"
            [ "${cpnl:-0}" -lt 0 ] 2>/dev/null && cpnl_color="$RED"
            printf "  ${GRAY}  %-17s${RESET}  ${hcolor}%-10s${RESET}  ${GRAY}%-10s  %-6s${RESET}  ${cpnl_color}%s USD${RESET}\n" \
                "$cts" "$cdec" "$cclose" "$cpos" "$cpnl"
        done
    fi

    echo ""
    printf "  ${GRAY}更新間隔: %s秒  終了: Ctrl+C${RESET}\n" "$INTERVAL"
}

# メインループ
trap 'echo -e "\n${CYAN}モニター終了${RESET}"; exit 0' INT TERM

while true; do
    show_dashboard
    sleep "$INTERVAL"
done
