#!/bin/bash
# prj-deploy - Raspberry Pi へのデプロイスクリプト
#
# 使用方法:
#   ./commands/prj-deploy                # git push + RPi git pull + BOT再起動 + 状態確認
#   ./commands/prj-deploy --no-restart   # BOT再起動なし（git pull のみ）
#   ./commands/prj-deploy --status-only  # デプロイせず RPi 状態確認のみ

# 色定義
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# オプション解析
NO_RESTART=0
STATUS_ONLY=0
for arg in "$@"; do
    case "$arg" in
        --no-restart)  NO_RESTART=1 ;;
        --status-only) STATUS_ONLY=1 ;;
    esac
done

RPi_HOST="raspberry_pi"
BRANCH="gen2"

echo -e "${BLUE}========================================"
echo "🚀 satosystem gen2 - RPi デプロイ"
echo -e "========================================${NC}"
echo ""

# ============================================================
# --status-only: デプロイをスキップして状態確認のみ
# ============================================================
if [ $STATUS_ONLY -eq 1 ]; then
    echo -e "${CYAN}ℹ️  --status-only: RPi 状態確認のみ実行${NC}"
    echo ""
else
    # ============================================================
    # Step 1: git push
    # ============================================================
    echo -e "${BLUE}📤 [1/4] git push origin ${BRANCH}${NC}"
    if git push origin "$BRANCH"; then
        echo -e "${GREEN}✅ git push 完了${NC}"
    else
        echo -e "${RED}❌ git push 失敗。デプロイを中止します。${NC}"
        exit 1
    fi
    echo ""

    # ============================================================
    # Step 2: RPi git pull（ローカル変更を stash で保護）
    # ============================================================
    echo -e "${BLUE}📥 [2/4] RPi: git pull origin ${BRANCH}${NC}"

    # ローカル変更を一時退避（back_test=0 等の本番設定を保護）
    STASH_OUT=$(ssh "$RPi_HOST" "cd ~/work/satosystem && git stash" 2>&1)
    echo "  git stash: $STASH_OUT"
    STASHED=0
    if echo "$STASH_OUT" | grep -q "Saved working directory"; then
        STASHED=1
        echo -e "  ${YELLOW}⚠️  RPi にローカル変更あり → stash で退避済み${NC}"
    fi

    # pull 実行
    if ssh "$RPi_HOST" "cd ~/work/satosystem && git pull origin $BRANCH"; then
        echo -e "${GREEN}✅ git pull 完了${NC}"
    else
        echo -e "${RED}❌ git pull 失敗。RPi の接続または状態を確認してください。${NC}"
        # stash していた場合は pop して戻す
        if [ $STASHED -eq 1 ]; then
            ssh "$RPi_HOST" "cd ~/work/satosystem && git stash pop" 2>/dev/null
        fi
        exit 1
    fi

    # ローカル変更を復元（back_test=0 等の本番設定を維持）
    if [ $STASHED -eq 1 ]; then
        POP_OUT=$(ssh "$RPi_HOST" "cd ~/work/satosystem && git stash pop" 2>&1)
        if echo "$POP_OUT" | grep -q "CONFLICT\|error"; then
            echo -e "  ${RED}❌ stash pop でコンフリクト発生。RPi で手動確認が必要です。${NC}"
            echo "  $POP_OUT"
        else
            echo -e "  ${GREEN}✅ RPi ローカル変更（back_test=0 等）を復元しました${NC}"
        fi
    fi
    echo ""

    # ============================================================
    # Step 3: BOT 再起動（--no-restart でスキップ）
    # ============================================================
    if [ $NO_RESTART -eq 1 ]; then
        echo -e "${YELLOW}⏭️  [3/4] --no-restart: BOT再起動をスキップ${NC}"
        echo ""
    else
        echo -e "${BLUE}🔄 [3/4] 両BOT 再起動${NC}"

        # BTC BOT 停止
        echo "  ⏹️  BTC BOT 停止中..."
        ssh "$RPi_HOST" "cd ~/work/satosystem/src && bash stop_bot.sh 2>/dev/null || true"

        # XAUT BOT 停止
        echo "  ⏹️  XAUT BOT 停止中..."
        ssh "$RPi_HOST" "cd ~/work/satosystem/src && bash stop_bot.sh --config config_xaut.ini 2>/dev/null || true"

        sleep 2

        # BTC BOT 起動
        echo "  🚀 BTC BOT 起動中..."
        ssh "$RPi_HOST" "cd ~/work/satosystem/src && bash start_bot.sh"
        BTC_RESULT=$?

        # XAUT BOT 起動
        echo "  🚀 XAUT BOT 起動中..."
        ssh "$RPi_HOST" "cd ~/work/satosystem/src && bash start_bot.sh --config config_xaut.ini"
        XAUT_RESULT=$?

        if [ $BTC_RESULT -eq 0 ] && [ $XAUT_RESULT -eq 0 ]; then
            echo -e "${GREEN}✅ 両BOT 起動成功${NC}"
        else
            echo -e "${RED}⚠️  一部BOTの起動に失敗した可能性があります${NC}"
        fi
        echo ""

        # 起動安定待機
        echo "  ⏳ 起動安定待機（5秒）..."
        sleep 5
        echo ""
    fi
fi

# ============================================================
# Step 4: RPi 状態確認
# ============================================================
STEP_NUM=4
if [ $STATUS_ONLY -eq 1 ]; then STEP_NUM=1; fi
if [ $NO_RESTART -eq 1 ]; then STEP_NUM=3; fi

echo -e "${BLUE}📊 [${STEP_NUM}/4] RPi 稼働状態チェック${NC}"
echo ""

# --- システム情報取得 ---
UPTIME=$(ssh "$RPi_HOST" "uptime" 2>/dev/null)
FREE=$(ssh "$RPi_HOST" "free -h" 2>/dev/null)
DISK=$(ssh "$RPi_HOST" "df -h /" 2>/dev/null)
TEMP_RAW=$(ssh "$RPi_HOST" "cat /sys/class/thermal/thermal_zone0/temp" 2>/dev/null)
TEMP=$(echo "$TEMP_RAW" | awk '{printf "%.1f", $1/1000}')
TOP_OUT=$(ssh "$RPi_HOST" "top -b -n1 | head -5" 2>/dev/null)

# --- BOTプロセス情報取得 ---
BOT_PS=$(ssh "$RPi_HOST" "ps aux | grep 'python3 -u bot.py' | grep -v grep" 2>/dev/null)

# --- ログファイル確認（最新のもの）---
BTC_LOG=$(ssh "$RPi_HOST" "ls -t ~/work/satosystem/src/logs/bot_BTC_*.log 2>/dev/null | head -1" 2>/dev/null)
XAUT_LOG=$(ssh "$RPi_HOST" "ls -t ~/work/satosystem/src/logs/xaut/bot_XAUT_*.log 2>/dev/null | head -1" 2>/dev/null)
BTC_LAST=$(ssh "$RPi_HOST" "tail -3 $BTC_LOG 2>/dev/null" 2>/dev/null)
XAUT_LAST=$(ssh "$RPi_HOST" "tail -3 $XAUT_LOG 2>/dev/null" 2>/dev/null)

echo -e "${CYAN}--- システム情報 ---${NC}"
echo "$UPTIME"
echo ""

# CPU負荷判定
LOAD=$(echo "$UPTIME" | grep -oP 'load average: \K[0-9.]+' | head -1)
LOAD_INT=$(echo "$LOAD * 10" | bc 2>/dev/null | cut -d. -f1)
if [ "${LOAD_INT:-0}" -lt 20 ]; then
    echo -e "  CPU負荷:   ${GREEN}${LOAD} ✅ 正常${NC}"
elif [ "${LOAD_INT:-0}" -lt 50 ]; then
    echo -e "  CPU負荷:   ${YELLOW}${LOAD} ⚠️ やや高い${NC}"
else
    echo -e "  CPU負荷:   ${RED}${LOAD} ❌ 高負荷${NC}"
fi

# CPU温度判定
TEMP_INT=$(echo "$TEMP" | cut -d. -f1)
if [ "${TEMP_INT:-0}" -lt 60 ]; then
    echo -e "  CPU温度:   ${GREEN}${TEMP}°C ✅ 正常${NC}"
elif [ "${TEMP_INT:-0}" -lt 75 ]; then
    echo -e "  CPU温度:   ${YELLOW}${TEMP}°C ⚠️ やや高い${NC}"
else
    echo -e "  CPU温度:   ${RED}${TEMP}°C ❌ 高温（サーマルスロットリングの可能性）${NC}"
fi

# メモリ判定
MEM_AVAIL=$(echo "$FREE" | grep '^Mem:' | awk '{print $7}')
echo -e "  メモリ利用可能: ${GREEN}${MEM_AVAIL} ✅${NC}"

# ディスク判定
DISK_PCT=$(echo "$DISK" | grep '/dev/' | awk '{print $5}' | tr -d '%')
if [ "${DISK_PCT:-0}" -lt 70 ]; then
    echo -e "  ディスク使用率: ${GREEN}${DISK_PCT}% ✅ 正常${NC}"
elif [ "${DISK_PCT:-0}" -lt 85 ]; then
    echo -e "  ディスク使用率: ${YELLOW}${DISK_PCT}% ⚠️ 要注意${NC}"
else
    echo -e "  ディスク使用率: ${RED}${DISK_PCT}% ❌ 残り僅か${NC}"
fi
echo ""

echo -e "${CYAN}--- BOT プロセス状態 ---${NC}"
if echo "$BOT_PS" | grep -q "bot.py$"; then
    BTC_PID=$(echo "$BOT_PS" | grep "bot.py$" | awk '{print $2}')
    BTC_CPU=$(echo "$BOT_PS" | grep "bot.py$" | awk '{print $3}')
    BTC_MEM=$(echo "$BOT_PS" | grep "bot.py$" | awk '{print $4}')
    echo -e "  BTC BOT:  ${GREEN}✅ 稼働中 (PID: ${BTC_PID}, CPU: ${BTC_CPU}%, MEM: ${BTC_MEM}%)${NC}"
else
    echo -e "  BTC BOT:  ${RED}❌ プロセスなし${NC}"
fi

if echo "$BOT_PS" | grep -q "config_xaut.ini"; then
    XAUT_PID=$(echo "$BOT_PS" | grep "config_xaut.ini" | awk '{print $2}')
    XAUT_CPU=$(echo "$BOT_PS" | grep "config_xaut.ini" | awk '{print $3}')
    XAUT_MEM=$(echo "$BOT_PS" | grep "config_xaut.ini" | awk '{print $4}')
    echo -e "  XAUT BOT: ${GREEN}✅ 稼働中 (PID: ${XAUT_PID}, CPU: ${XAUT_CPU}%, MEM: ${XAUT_MEM}%)${NC}"
else
    echo -e "  XAUT BOT: ${RED}❌ プロセスなし${NC}"
fi
echo ""

echo -e "${CYAN}--- 最新ログ確認 ---${NC}"
echo -e "  ${BLUE}BTC:${NC}"
echo "$BTC_LAST" | sed 's/^/    /'
echo ""
echo -e "  ${BLUE}XAUT:${NC}"
echo "$XAUT_LAST" | sed 's/^/    /'
echo ""

echo -e "${BLUE}========================================${NC}"
if [ $STATUS_ONLY -eq 1 ]; then
    echo -e "${GREEN}✅ RPi 状態確認完了${NC}"
else
    echo -e "${GREEN}🎉 デプロイ完了${NC}"
fi
echo -e "${BLUE}========================================${NC}"
