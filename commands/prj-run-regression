#!/bin/bash

# /prj-run-regression - レグレッションテスト統合実行スクリプト
# 
# 目的: コミット前にテストをまとめて実行し、結果を検証する
# 実行内容:
#   1. run_quarterly_backtest.py - 四半期別バックテスト実行
#   2. regression_test_suite.py - レグレッションテストスイート実行
#   3. backtest_and_visualize.sh - バックテスト＋グラフ生成

set -e  # エラー時に即座に終了

# 色定義
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# ヘッダー表示
echo -e "${BLUE}========================================"
echo "🧪 satosystem gen2 - Regression Test Suite"
echo "========================================${NC}"
echo ""
echo "📋 実行内容:"
echo "  1. run_quarterly_backtest.py - 四半期別バックテスト"
echo "  2. regression_test_suite.py - レグレッションテスト"
echo "  3. backtest_and_visualize.sh - バックテスト＋可視化"
echo ""

# 開始時刻記録
START_TIME=$(date +%s)

# エラーカウンタ
ERRORS=0

# ======================================
# Test 1: run_quarterly_backtest.py
# ======================================
echo -e "${YELLOW}========================================${NC}"
echo -e "${YELLOW}📊 Test 1: 四半期別バックテスト実行${NC}"
echo -e "${YELLOW}========================================${NC}"
echo ""

if python3 run_quarterly_backtest.py; then
    echo -e "${GREEN}✅ run_quarterly_backtest.py - 正常終了${NC}"
else
    echo -e "${RED}❌ run_quarterly_backtest.py - 失敗${NC}"
    ERRORS=$((ERRORS + 1))
fi
echo ""

# ======================================
# Test 2: regression_test_suite.py
# ======================================
echo -e "${YELLOW}========================================${NC}"
echo -e "${YELLOW}🧪 Test 2: レグレッションテストスイート実行${NC}"
echo -e "${YELLOW}========================================${NC}"
echo ""

if python3 test/regression_test_suite.py; then
    echo -e "${GREEN}✅ regression_test_suite.py - テスト正常完了${NC}"
else
    echo -e "${RED}❌ regression_test_suite.py - テスト失敗${NC}"
    ERRORS=$((ERRORS + 1))
fi
echo ""

# ======================================
# Test 3: backtest_and_visualize.sh
# ======================================
echo -e "${YELLOW}========================================${NC}"
echo -e "${YELLOW}📈 Test 3: バックテスト＋可視化実行${NC}"
echo -e "${YELLOW}========================================${NC}"
echo ""

if bash backtest_and_visualize.sh; then
    echo -e "${GREEN}✅ backtest_and_visualize.sh - グラフ生成完了${NC}"
    
    # グラフファイルの存在確認
    GRAPH_COUNT=$(find report -name "*.html" 2>/dev/null | wc -l)
    if [ "$GRAPH_COUNT" -gt 0 ]; then
        echo -e "${GREEN}   ✓ グラフファイル生成確認: ${GRAPH_COUNT}件${NC}"
    else
        echo -e "${YELLOW}   ⚠ 警告: report/にHTMLグラフが見つかりません${NC}"
    fi
else
    echo -e "${RED}❌ backtest_and_visualize.sh - 失敗${NC}"
    ERRORS=$((ERRORS + 1))
fi
echo ""

# ======================================
# 結果サマリー
# ======================================
END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))
MINUTES=$((ELAPSED / 60))
SECONDS=$((ELAPSED % 60))

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}📊 テスト結果サマリー${NC}"
echo -e "${BLUE}========================================${NC}"
echo ""

if [ $ERRORS -eq 0 ]; then
    echo -e "${GREEN}✅ 全テスト成功 (0 failures)${NC}"
    echo -e "${GREEN}   実行時間: ${MINUTES}分${SECONDS}秒${NC}"
    echo ""
    echo -e "${GREEN}🎉 コミット可能な状態です${NC}"
    exit 0
else
    echo -e "${RED}❌ テスト失敗: ${ERRORS}件${NC}"
    echo -e "${RED}   実行時間: ${MINUTES}分${SECONDS}秒${NC}"
    echo ""
    echo -e "${RED}⚠️  コミット前にエラーを修正してください${NC}"
    exit 1
fi
