#!/bin/bash
# prj-run-regression - レグレッションテスト実行スクリプト
#
# 使用方法:
#   ./commands/prj-run-regression          # 通常モード: レグレッションテストのみ (高速)
#   ./commands/prj-run-regression --full   # フルモード: 四半期バックテスト + 可視化も実行

# 色定義
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

FULL_MODE=0
if [ "$1" = "--full" ]; then
    FULL_MODE=1
fi

echo -e "${BLUE}========================================"
echo "🧪 satosystem gen2 - Regression Test Suite"
if [ $FULL_MODE -eq 1 ]; then
    echo "   モード: フル (四半期バックテスト + 可視化含む)"
else
    echo "   モード: 通常 (レグレッションテストのみ)"
    echo "   ヒント: --full オプションで全テスト実行"
fi
echo -e "========================================${NC}"
echo ""

# プロジェクトルート確認
if [ ! -f "PROGRESS.json" ]; then
    echo -e "${RED}❌ エラー: プロジェクトルートから実行してください${NC}"
    exit 1
fi

START_TIME=$(date +%s)
ERRORS=0

# ======================================
# フルモード: Test 1 - 四半期別バックテスト（BTC）
# ======================================
if [ $FULL_MODE -eq 1 ]; then
    echo -e "${YELLOW}========================================${NC}"
    echo -e "${YELLOW}📊 Test 1a: 四半期別バックテスト実行 [BTC]${NC}"
    echo -e "${YELLOW}========================================${NC}"
    if python3 run_quarterly_backtest.py; then
        echo -e "${GREEN}✅ run_quarterly_backtest.py [BTC] - 正常終了${NC}"
    else
        echo -e "${RED}❌ run_quarterly_backtest.py [BTC] - 失敗${NC}"
        ERRORS=$((ERRORS + 1))
    fi
    echo ""

    echo -e "${YELLOW}========================================${NC}"
    echo -e "${YELLOW}📊 Test 1b: 四半期別バックテスト実行 [XAUT]${NC}"
    echo -e "${YELLOW}========================================${NC}"
    if python3 run_quarterly_backtest.py --config config_xaut.ini; then
        echo -e "${GREEN}✅ run_quarterly_backtest.py [XAUT] - 正常終了${NC}"
    else
        echo -e "${RED}❌ run_quarterly_backtest.py [XAUT] - 失敗${NC}"
        ERRORS=$((ERRORS + 1))
    fi
    echo ""
fi

# ======================================
# Test 2: regression_test_suite.py (常時実行)
# ======================================
echo -e "${YELLOW}========================================${NC}"
echo -e "${YELLOW}🧪 レグレッションテストスイート実行${NC}"
echo -e "${YELLOW}========================================${NC}"
echo ""

if python3 test/regression_test_suite.py; then
    echo -e "${GREEN}✅ regression_test_suite.py - 全テスト合格${NC}"
else
    echo -e "${RED}❌ regression_test_suite.py - テスト失敗${NC}"
    ERRORS=$((ERRORS + 1))
fi
echo ""

# ======================================
# フルモード: Test 3 - バックテスト＋可視化
# ======================================
if [ $FULL_MODE -eq 1 ]; then
    echo -e "${YELLOW}========================================${NC}"
    echo -e "${YELLOW}📈 Test 3a: バックテスト＋可視化実行 [BTC]${NC}"
    echo -e "${YELLOW}========================================${NC}"
    if bash backtest_and_visualize.sh; then
        GRAPH_COUNT=$(find report -name "*.html" 2>/dev/null | wc -l)
        echo -e "${GREEN}✅ backtest_and_visualize.sh [BTC] - 完了 (グラフ: ${GRAPH_COUNT}件)${NC}"
    else
        echo -e "${RED}❌ backtest_and_visualize.sh [BTC] - 失敗${NC}"
        ERRORS=$((ERRORS + 1))
    fi
    echo ""

    echo -e "${YELLOW}========================================${NC}"
    echo -e "${YELLOW}📈 Test 3b: バックテスト＋可視化実行 [XAUT]${NC}"
    echo -e "${YELLOW}========================================${NC}"
    # quarterly 実行後に config_xaut.ini の日付が Q1 2026 になるため、
    # 通年テスト用に全期間（2024/01/01〜2026/05/08）へ戻す
    sed -i 's|^start_time = .*|start_time = 2024/01/01 00:00|' src/config_xaut.ini
    sed -i 's|^end_time = .*|end_time = 2026/05/08 23:59|' src/config_xaut.ini
    echo "config_xaut.ini: 通年テスト期間 2024/01/01〜2026/05/08 に設定"
    if bash backtest_and_visualize_xaut.sh; then
        echo -e "${GREEN}✅ backtest_and_visualize_xaut.sh [XAUT] - 完了${NC}"
    else
        echo -e "${RED}❌ backtest_and_visualize_xaut.sh [XAUT] - 失敗${NC}"
        ERRORS=$((ERRORS + 1))
    fi
    echo ""
fi

# ======================================
# 結果サマリー
# ======================================
END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))
MINUTES=$((ELAPSED / 60))
SECONDS=$((ELAPSED % 60))

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}📊 テスト結果サマリー${NC}"
echo -e "${BLUE}========================================${NC}"

if [ $ERRORS -eq 0 ]; then
    echo -e "${GREEN}✅ 全テスト成功 (0 failures)  実行時間: ${MINUTES}分${SECONDS}秒${NC}"
    echo ""
    echo -e "${GREEN}🎉 コミット可能な状態です${NC}"
    exit 0
else
    echo -e "${RED}❌ テスト失敗: ${ERRORS}件  実行時間: ${MINUTES}分${SECONDS}秒${NC}"
    echo ""
    echo -e "${RED}⚠️  コミット前にエラーを修正してください${NC}"
    exit 1
fi
