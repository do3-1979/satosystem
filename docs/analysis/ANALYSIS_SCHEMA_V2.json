{
  "schema_version": "2.0",
  "metadata": {
    "description": "拡張ソースコード分析スキーマ（Level 1-5統合）",
    "created_at": "2026-01-01",
    "objective": "プロジェクト全容把握・設計検証・リファクタリング計画の根拠となる包括的な分析情報"
  },

  "file_info": {
    "type": "object",
    "properties": {
      "source_file": {
        "type": "string",
        "description": "Pythonソースファイルのパス",
        "example": "src/bot.py"
      },
      "purpose": {
        "type": "string",
        "description": "ファイル全体の役割・目的（1-2文）",
        "example": "トレード実行ループの制御とポジション管理"
      },
      "lines_of_code": {
        "type": "integer",
        "description": "推定行数（コメント除外）"
      },
      "dependency_count": {
        "type": "integer",
        "description": "他モジュールへの依存数"
      },
      "class_count": {
        "type": "integer"
      },
      "function_count": {
        "type": "integer"
      },
      "critical_methods": {
        "type": "array",
        "description": "システムの重要性が高いメソッド",
        "items": {"type": "string"}
      }
    }
  },

  "class_schema": {
    "type": "object",
    "properties": {
      "class_name": {
        "type": "string"
      },
      "line": {
        "type": "integer"
      },
      "docstring": {
        "type": "string"
      },
      "inheritance": {
        "type": "array",
        "items": {"type": "string"},
        "description": "親クラス一覧"
      },

      "responsibility": {
        "type": "object",
        "description": "Level 1: クラス単位の責務定義",
        "properties": {
          "primary": {
            "type": "string",
            "description": "第一責務（1文で表現）",
            "example": "トレード実行ループの制御・調整"
          },
          "secondary": {
            "type": "array",
            "items": {"type": "string"},
            "description": "補助責務",
            "example": ["ログ記録", "ポジション状態管理", "例外回復"]
          },
          "scope": {
            "type": "string",
            "enum": ["GLOBAL", "MODULE", "DOMAIN", "UTILITY"],
            "description": "クラスの適用範囲",
            "example": "GLOBAL"
          },
          "criticality": {
            "type": "string",
            "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"],
            "description": "システムへの重要度"
          },
          "testing_priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "テスト優先度（1=最優先）"
          }
        },
        "required": ["primary", "scope", "criticality", "testing_priority"]
      },

      "dependencies": {
        "type": "object",
        "description": "Level 2: モジュール間依存関係",
        "properties": {
          "imports": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "module": {
                  "type": "string",
                  "example": "trading_strategy"
                },
                "class_or_function": {
                  "type": "string",
                  "example": "TradingStrategy"
                },
                "usage": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "in_method": {
                        "type": "string",
                        "example": "run"
                      },
                      "purpose": {
                        "type": "string",
                        "example": "トレード判定取得"
                      },
                      "dependency_type": {
                        "type": "string",
                        "enum": ["STRONG", "WEAK", "CONDITIONAL"],
                        "description": "STRONG=毎回、WEAK=条件付き、CONDITIONAL=フラグ依存"
                      },
                      "frequency": {
                        "type": "string",
                        "enum": ["EVERY_CALL", "CONDITIONAL", "RARE"],
                        "description": "呼び出し頻度"
                      }
                    }
                  }
                },
                "is_optional": {
                  "type": "boolean",
                  "description": "インポートなしで動作可能か"
                },
                "is_cyclic": {
                  "type": "boolean",
                  "description": "循環依存の有無"
                }
              }
            }
          },
          "dependents": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "module": {
                  "type": "string"
                },
                "usage_methods": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "count": {
                  "type": "integer"
                }
              }
            },
            "description": "このモジュールに依存する外部モジュール"
          }
        }
      },

      "attributes": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "type": {"type": "string"},
            "visibility": {
              "enum": ["public", "private", "protected"]
            },
            "description": {"type": "string"}
          }
        }
      },

      "methods": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "line": {"type": "integer"},
            "signature": {"type": "string"},
            "visibility": {
              "enum": ["public", "private", "protected"]
            },
            "is_classmethod": {"type": "boolean"},
            "is_staticmethod": {"type": "boolean"},
            "docstring": {"type": "string"},

            "method_type": {
              "type": "string",
              "enum": ["ACTION", "QUERY", "UTILITY", "INIT", "CLEANUP"],
              "description": "Level 1: メソッド分類"
            },
            "purpose": {
              "type": "string",
              "description": "機能目的（1-2文）"
            },
            "entry_conditions": {
              "type": "array",
              "items": {"type": "string"},
              "description": "呼び出し前の前提条件"
            },
            "exit_outcomes": {
              "type": "array",
              "items": {"type": "string"},
              "description": "メソッド実行後の結果状態"
            },
            "state_changes": {
              "type": "array",
              "items": {"type": "string"},
              "description": "副作用（変更する属性・外部状態）"
            },
            "criticality": {
              "type": "string",
              "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"]
            },

            "data_flow": {
              "type": "object",
              "description": "Level 2: 入出力データフロー",
              "properties": {
                "inputs": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "source": {
                        "type": "string",
                        "description": "データソース（モジュール/クラス）",
                        "example": "price_data_management"
                      },
                      "attribute": {
                        "type": "string",
                        "description": "属性/メソッド名"
                      },
                      "type": {
                        "type": "string",
                        "description": "データ型"
                      },
                      "used_in": {
                        "type": "string",
                        "description": "この入力が何に使われるか"
                      }
                    }
                  }
                },
                "outputs": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "destination": {
                        "type": "string",
                        "description": "呼び出し元"
                      },
                      "return_value": {
                        "type": "string",
                        "description": "戻り値の型"
                      },
                      "contents": {
                        "type": "string",
                        "description": "具体的な内容例"
                      }
                    }
                  }
                },
                "side_effects": {
                  "type": "array",
                  "items": {"type": "string"},
                  "description": "副作用（戻り値以外の変化）"
                }
              }
            },

            "error_handling": {
              "type": "object",
              "description": "Level 3: エラーハンドリング",
              "properties": {
                "exceptions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "exception_type": {"type": "string"},
                      "location": {"type": "string"},
                      "recovery_strategy": {
                        "enum": ["RETRY", "FALLBACK", "ABORT", "IGNORE"],
                        "description": "復帰戦略"
                      },
                      "max_retries": {
                        "type": "integer"
                      },
                      "fallback_action": {
                        "type": "string"
                      },
                      "log_level": {
                        "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]
                      }
                    }
                  }
                },
                "failure_modes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "scenario": {
                        "type": "string",
                        "example": "ネットワーク断絶"
                      },
                      "impact": {
                        "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"]
                      },
                      "handling": {
                        "type": "string"
                      },
                      "data_loss_risk": {
                        "type": "boolean"
                      }
                    }
                  }
                }
              }
            },

            "testability": {
              "type": "object",
              "description": "Level 4: テスト容易性",
              "properties": {
                "is_testable": {"type": "boolean"},
                "dependencies_count": {"type": "integer"},
                "difficulty": {
                  "enum": ["EASY", "MEDIUM", "HARD"]
                },
                "suggested_test_cases": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {"type": "string"},
                      "type": {
                        "enum": ["UNIT", "INTEGRATION", "E2E"]
                      },
                      "setup": {"type": "string"},
                      "expected_output": {"type": "string"},
                      "edge_cases": {
                        "type": "array",
                        "items": {"type": "string"}
                      }
                    }
                  }
                }
              }
            },

            "performance": {
              "type": "object",
              "description": "Level 5: パフォーマンス・スケーリング",
              "properties": {
                "time_complexity": {
                  "type": "string",
                  "example": "O(n)"
                },
                "space_complexity": {
                  "type": "string",
                  "example": "O(1)"
                },
                "typical_execution_time_ms": {
                  "type": "number"
                },
                "bottlenecks": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "operation": {"type": "string"},
                      "current_time_ms": {"type": "number"},
                      "optimization_potential": {"type": "string"}
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },

  "summary": {
    "type": "object",
    "properties": {
      "architecture_score": {
        "type": "number",
        "minimum": 0,
        "maximum": 10,
        "description": "設計品質スコア"
      },
      "testability_score": {
        "type": "number",
        "minimum": 0,
        "maximum": 10
      },
      "maintainability_score": {
        "type": "number",
        "minimum": 0,
        "maximum": 10
      },
      "critical_issues": {
        "type": "array",
        "items": {"type": "string"}
      },
      "recommendations": {
        "type": "array",
        "items": {"type": "string"}
      }
    }
  }
}
